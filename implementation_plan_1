### 2. Database Schema (Prisma)

#### [NEW] [schema.prisma](file:///c:/Users/dl/Desktop/Main_Projects_V2/100xproject/3-slate/prisma/schema.prisma)

Define three models:

```prisma
model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String?           // null for Google-only users
  image          String?
  googleId       String?   @unique // for Google OAuth
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  memberships    Member[]          // user can belong to many orgs
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique      // URL-friendly name
  createdAt   DateTime @default(now())
  members     Member[]
}

model Member {
  id             String       @id @default(cuid())
  role           String       @default("member")  // "owner" | "admin" | "member"
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  @@unique([userId, organizationId])  // one membership per org per user
}
```

